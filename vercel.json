{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "app/backend/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app/backend/app.js" },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
